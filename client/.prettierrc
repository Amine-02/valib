{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "plugins": ["prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": ["*.html"],
      "options": {
        "htmlWhitespaceSensitivity": "ignore",
        "printWidth": 120,
        "singleAttributePerLine": false,
        "bracketSameLine": true,
        "tabWidth": 2
      }
    }
  ]
}
